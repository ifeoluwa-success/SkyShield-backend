# ========================
# Django Core Settings
# ========================
SECRET_KEY=your_secret_key_here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,skyshield-backend.onrender.com
FRONTEND_URL=https://skyshieldedu.com

# ========================
# Database Settings
# ========================
DB_NAME=skyshield_db
DB_USER=skyshield_user
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# ========================
# Email Service (Anymail)
# ========================
EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
DEFAULT_FROM_EMAIL=SkyShield <noreply@skyshieldedu.com>
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_SENDER_DOMAIN=your_mailgun_domain

# ========================
# Social Auth Credentials
# ========================
SOCIAL_AUTH_GOOGLE_CLIENT_ID=your_google_client_id
SOCIAL_AUTH_GOOGLE_SECRET=your_google_secret
SOCIAL_AUTH_GITHUB_CLIENT_ID=your_github_client_id
SOCIAL_AUTH_GITHUB_SECRET=your_github_secret

# ========================
# Redis & Channels
# ========================
REDIS_URL=redis://127.0.0.1:6379/0